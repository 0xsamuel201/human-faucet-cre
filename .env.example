CRE_TARGET=staging-settings
# Etherscan API Key
ETHERSCAN_API_KEY=
# CRE Relayer address
SEPOLIA_CRE_FORWARDER_ADDRESS=
ARB_SEPOLIA_CRE_FORWARDER_ADDRESS=